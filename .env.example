# Stripe — NEVER commit the real key. Use .env (already gitignored).
STRIPE_SECRET_KEY=sk_test_...

# Stripe Price ID for NoConflict Pro ($29/mo recurring)
# Create via: Stripe Dashboard → Products → Add product → $29/mo recurring
NC_STRIPE_PRICE_ID=price_...

# Checkout redirect URLs (optional — defaults to noconflict.dev)
# NC_CHECKOUT_SUCCESS_URL=https://noconflict.dev/pro/success
# NC_CHECKOUT_CANCEL_URL=https://noconflict.dev/pro
